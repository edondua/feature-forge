# Task Orchestration API Keys
ANTHROPIC_API_KEY=sk-ant-...
LINEAR_API_KEY=lin_api_...

# Figma — for Design System Audit (scan components, generate specs)
# FIGMA_ACCESS_TOKEN=figd_...

# GitHub — for Design Audit code scanning (scans Swift/Kotlin files via API)
# GITHUB_TOKEN=ghp_...             # Required for private repos, optional for public

# Code repos — GitHub URLs (recommended) or local filesystem paths
# IOS_REPO_URL=https://github.com/yourorg/ios-app
# ANDROID_REPO_URL=https://github.com/yourorg/android-app
# IOS_REPO_PATH=/Users/yourname/repos/ios-app       # Local fallback
# ANDROID_REPO_PATH=/Users/yourname/repos/android-app  # Local fallback

# Google Stitch — AI design tool for UX proposal generation (optional)
# Generate at: stitch.withgoogle.com → Profile → Settings → API Key
# STITCH_API_KEY=stitch_...

# Linear Webhook — External trigger for design proposals (optional)
# LINEAR_WEBHOOK_SECRET=whsec_...

# App password — protects the Futurist Setup UI (shown on login screen)
VITE_APP_PASSWORD=futurist

# GitNexus (Gitea/Forgejo) — for auto-detecting services from your repos
# GITNEXUS_URL=https://git.yourcompany.com
# GITNEXUS_TOKEN=your_gitea_token
# GITNEXUS_ORG=your_org_or_user   (optional — scope to a specific org/user)

# Local monorepo path — scans service directories directly, no API needed
# GITNEXUS_LOCAL_PATH=/Users/yourname/dua-base
